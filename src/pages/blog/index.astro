---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts');
posts.sort((a, b) => new Date(b.data.fecha).getTime() - new Date(a.data.fecha).getTime());
---

<BaseLayout title="Blog | Editorial Olave Family">
  <section class="py-12 sm:py-16">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <header class="mb-12">
        <h1 class="font-serif text-4xl sm:text-5xl font-bold text-stone-900 mb-4">Blog</h1>
        <p class="text-lg text-stone-600 max-w-2xl">Noticias, novedades y reflexiones desde Editorial Olave Family.</p>
      </header>

      <div class="space-y-10">
        {posts.map(post => (
          <article class="border-b border-stone-200 pb-10 last:border-0">
            <p class="text-sm text-stone-500 mb-2">
              {new Date(post.data.fecha).toLocaleDateString('es-CL', { year: 'numeric', month: 'long', day: 'numeric' })}
            </p>
            <h2 class="font-serif text-2xl font-bold text-stone-900 mb-3">
              <a href={`/blog/${post.data.slug}/`} class="hover:text-amber-800 transition-colors">{post.data.titulo}</a>
            </h2>
            <p class="text-stone-600 mb-4">{post.data.resumen}</p>
            <a href={`/blog/${post.data.slug}/`} class="text-stone-900 font-medium border-b border-stone-900 pb-0.5 hover:text-amber-800 hover:border-amber-800 transition-colors">Leer más →</a>
          </article>
        ))}
      </div>

      {posts.length === 0 && (
        <p class="text-stone-500 text-center py-16">Próximamente nuevas publicaciones.</p>
      )}
    </div>
  </section>
</BaseLayout>
