---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contacto | Editorial Olave Family">
  <section class="py-12 sm:py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <header class="mb-12 text-center">
        <h1 class="font-serif text-4xl sm:text-5xl font-bold text-stone-900 mb-4">Contacto</h1>
        <p class="text-lg text-stone-600">¿Interesado en nuestros libros? Escríbenos.</p>
      </header>

      <div class="bg-white rounded-lg shadow-sm border border-stone-200 p-8">
        <div class="space-y-6">
          <div>
            <h3 class="font-medium text-stone-900 mb-1">Email</h3>
            <a href="mailto:info@olavefamily.com" class="text-stone-600 hover:text-amber-800 transition-colors">info@olavefamily.com</a>
          </div>
          <div>
            <h3 class="font-medium text-stone-900 mb-1">Ubicación</h3>
            <p class="text-stone-600">Casablanca, Chile</p>
          </div>
          <div>
            <h3 class="font-medium text-stone-900 mb-2">Consultas directas</h3>
            <p class="text-stone-600">Si prefieres adquirir nuestros libros fuera de Amazon, o deseas consultar por disponibilidad directa, envíos locales o copias firmadas, escríbenos directamente.</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
