---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const libros = await getCollection('libros');
const autores = await getCollection('autores');
---

<BaseLayout title="Editorial Olave Family | Libros, memorias y teatro" description="Editorial independiente dedicada a la publicación de memorias, teatro y obras familiares con enfoque humano y cultural." image="https://olavefamily.com/images/portada1.webp">
  <!-- Hero -->
  <section class="bg-stone-100">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-24">
      <div class="max-w-2xl">
        <p class="text-sm font-medium tracking-widest uppercase text-amber-800 mb-4">Editorial Independiente</p>
        <h1 class="font-serif text-4xl sm:text-5xl lg:text-6xl font-bold leading-tight text-stone-900 mb-6">
          Editorial Olave Family
        </h1>
        <p class="text-lg sm:text-xl text-stone-600 leading-relaxed mb-8">
          Memorias, narrativa autobiográfica y obras que nacen desde la experiencia vivida.
        </p>
        <div class="flex flex-wrap gap-4">
          <a 
            href="/libros"
            class="inline-block bg-stone-900 text-white px-6 py-3 rounded-lg font-medium hover:bg-stone-800 transition-colors"
          >
            Explorar libros
          </a>
          <a 
            href="/editorial"
            class="inline-block border-2 border-stone-900 text-stone-900 px-6 py-3 rounded-lg font-medium hover:bg-stone-900 hover:text-white transition-colors"
          >
            Conocer la editorial
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Nuestros libros -->
  <section class="py-16 sm:py-20">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <header class="mb-12">
        <h2 class="font-serif text-3xl font-bold text-stone-900 mb-2">Nuestros libros</h2>
        <p class="text-stone-600">Historias reales, memorias íntimas y obras que nacen desde la experiencia vivida.</p>
      </header>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {libros.map(libro => (
          <a href={`/libros/${libro.data.slug}/`} class="group block">
            <div class="aspect-[2/3] bg-stone-200 rounded-lg overflow-hidden shadow-sm mb-4">
              {libro.data.portada ? (
                <img src={libro.data.portada} alt={libro.data.titulo} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
              ) : (
                <div class="w-full h-full flex items-center justify-center text-stone-400 p-6 text-center">
                  <p class="font-serif text-lg font-bold text-stone-600">{libro.data.titulo}</p>
                </div>
              )}
            </div>
            <h3 class="font-serif text-xl font-bold text-stone-900 group-hover:text-amber-800 transition-colors">{libro.data.titulo}</h3>
            <p class="text-sm text-stone-500 mt-1">{libro.data.genero} · {libro.data.anio}</p>
            <p class="text-stone-600 mt-2 line-clamp-3">{libro.data.sinopsis}</p>
          </a>
        ))}
      </div>

      {libros.length === 0 && (
        <p class="text-stone-500 text-center py-16">Próximamente nuevas publicaciones.</p>
      )}
    </div>
  </section>

  <!-- Nuestros autores -->
  <section class="py-16 sm:py-20 bg-stone-50">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <header class="mb-12">
        <h2 class="font-serif text-3xl font-bold text-stone-900 mb-2">Nuestros autores</h2>
        <p class="text-stone-600">Voces que escriben desde la experiencia, la memoria y el coraje de contar lo vivido.</p>
      </header>

      <div class="grid sm:grid-cols-2 gap-8">
        {autores.map(autor => (
          <a href={`/autores/${autor.data.slug}/`} class="group flex gap-6 items-start">
            <div class="w-32 h-32 sm:w-40 sm:h-40 flex-shrink-0 bg-stone-200 rounded-full overflow-hidden shadow-sm">
              {autor.data.foto ? (
                <img src={autor.data.foto} alt={autor.data.nombre} class="w-full h-full object-cover" />
              ) : (
                <div class="w-full h-full flex items-center justify-center text-stone-400">
                  <span class="font-serif text-sm text-stone-500 text-center px-4">{autor.data.nombre}</span>
                </div>
              )}
            </div>
            <div class="flex-1 pt-2">
              <h3 class="font-serif text-2xl font-bold text-stone-900 group-hover:text-amber-800 transition-colors mb-2">{autor.data.nombre}</h3>
              {autor.data.profesion && (
                <p class="text-sm text-amber-800 font-medium mb-2">{autor.data.profesion}</p>
              )}
              <p class="text-stone-600 line-clamp-3">{autor.data.bioCorta}</p>
            </div>
          </a>
        ))}
      </div>

      {autores.length === 0 && (
        <p class="text-stone-500 text-center py-16">Próximamente nuevos autores.</p>
      )}
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 sm:py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-serif text-3xl font-bold text-stone-900 mb-4">¿Tienes una historia que contar?</h2>
      <p class="text-stone-600 leading-relaxed mb-8">
        Editorial Olave Family acompaña a autores que desean publicar obras íntimas, memorias o narrativa autobiográfica. Si crees que tu historia merece ser preservada, conversemos.
      </p>
      <a 
        href="/contacto"
        class="inline-block bg-stone-900 text-white px-8 py-3 rounded-lg font-medium hover:bg-stone-800 transition-colors"
      >
        Contactar
      </a>
    </div>
  </section>
</BaseLayout>
