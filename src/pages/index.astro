---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const libros = await getCollection('libros');
const autores = await getCollection('autores');
const destacado = libros.find(l => l.data.destacado) || libros[0];
const autorDestacado = destacado ? autores.find(a => a.data.slug === destacado.data.autorSlug) : autores[0];
---

<BaseLayout title="Editorial Olave Family | Libros, memorias y teatro">
  <!-- Hero -->
  <section class="bg-stone-100">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-24">
      <div class="max-w-2xl">
        <p class="text-sm font-medium tracking-widest uppercase text-amber-800 mb-4">Editorial Independiente</p>
        <h1 class="font-serif text-4xl sm:text-5xl lg:text-6xl font-bold leading-tight text-stone-900 mb-6">
          Editorial Olave Family
        </h1>
        <p class="text-lg sm:text-xl text-stone-600 leading-relaxed mb-8">
          Proyecto editorial independiente dedicado a la publicación y preservación de obras que nacen desde la experiencia, la creación y la transmisión cultural.
        </p>
        <p class="text-stone-500 italic">
          Un proyecto familiar dedicado a cuidar la palabra escrita.
        </p>
      </div>
    </div>
  </section>

  <!-- Libro destacado -->
  {destacado && (
    <section class="py-16 sm:py-20">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid md:grid-cols-2 gap-12 items-center">
          <div class="aspect-[2/3] bg-stone-200 rounded-lg overflow-hidden shadow-lg relative">
            <div class="absolute inset-0 flex items-center justify-center text-stone-400">
              <div class="text-center p-8">
                <p class="font-serif text-2xl font-bold text-stone-600 mb-2">{destacado.data.titulo}</p>
                <p class="text-sm text-stone-500">{destacado.data.genero}</p>
              </div>
            </div>
          </div>
          <div>
            <p class="text-sm font-medium tracking-widest uppercase text-amber-800 mb-3">
              {destacado.data.genero} · {destacado.data.anio}
            </p>
            <h2 class="font-serif text-3xl sm:text-4xl font-bold text-stone-900 mb-4">
              {destacado.data.titulo}
            </h2>
            <p class="text-stone-600 italic mb-2">{destacado.data.subtitulo}</p>
            <p class="text-stone-600 leading-relaxed mb-6">{destacado.data.sinopsis}</p>
            <a 
              href={`/libros/${destacado.data.slug}/`}
              class="inline-flex items-center gap-2 text-stone-900 font-medium border-b-2 border-amber-800 pb-1 hover:text-amber-800 transition-colors"
            >
              Ver el libro <span aria-hidden="true">→</span>
            </a>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Autora destacada -->
  {autorDestacado && (
    <section class="py-16 sm:py-20 bg-stone-50">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid md:grid-cols-2 gap-12 items-center">
          <div class="order-2 md:order-1">
            <p class="text-sm font-medium tracking-widest uppercase text-amber-800 mb-3">Autora Destacada</p>
            <h2 class="font-serif text-3xl sm:text-4xl font-bold text-stone-900 mb-4">
              {autorDestacado.data.nombre}
            </h2>
            <p class="text-stone-600 leading-relaxed mb-6">{autorDestacado.data.bioCorta}</p>
            <a 
              href={`/autores/${autorDestacado.data.slug}/`}
              class="inline-flex items-center gap-2 text-stone-900 font-medium border-b-2 border-amber-800 pb-1 hover:text-amber-800 transition-colors"
            >
              Conocer a la autora <span aria-hidden="true">→</span>
            </a>
          </div>
          <div class="order-1 md:order-2 aspect-square bg-stone-200 rounded-full overflow-hidden shadow-md max-w-sm mx-auto md:mx-0 md:ml-auto relative">
            <div class="absolute inset-0 flex items-center justify-center text-stone-400">
              <span class="font-serif text-lg text-stone-500">{autorDestacado.data.nombre}</span>
            </div>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- CTA / Newsletter -->
  <section class="py-16 sm:py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-serif text-3xl font-bold text-stone-900 mb-4">Un proyecto familiar</h2>
      <p class="text-stone-600 leading-relaxed mb-8">
        Editorial Olave Family es un proyecto que nace desde la memoria, la ternura y el deseo de preservar historias que merecen ser contadas. Si te conmueven las historias verdaderas, los relatos epistolares y los amores imposibles que se hacen posibles, este espacio es para ti.
      </p>
      <a 
        href="/contacto"
        class="inline-block bg-stone-900 text-white px-8 py-3 rounded-lg font-medium hover:bg-stone-800 transition-colors"
      >
        Contactar
      </a>
    </div>
  </section>
</BaseLayout>
